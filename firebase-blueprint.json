{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Herbal products available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Spiritual consultation and divination requests",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string" },
        "type": { "type": "string", "enum": ["Ifa Divination", "Spiritual Guidance", "Destiny Reading", "Spiritual Cleansing", "Traditional Healing"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "questions": { "type": "string" },
        "results": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientUid", "type", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders for herbal products",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientUid", "items", "totalAmount", "status", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational courses in the Ifa training academy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor": { "type": "string" },
        "price": { "type": "number" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Individual lessons within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "order"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection of user profiles" },
    "products": { "schema": "Product", "description": "Collection of herbal products" },
    "consultations": { "schema": "Consultation", "description": "Collection of consultation bookings" },
    "orders": { "schema": "Order", "description": "Collection of product orders" },
    "courses": { "schema": "Course", "description": "Collection of training courses" },
    "courses/{courseId}/lessons": { "schema": "Lesson", "description": "Sub-collection of lessons for a specific course" }
  }
}
