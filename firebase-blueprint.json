{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super-admin", "admin", "client"] },
        "adminLevel": { "type": "integer", "description": "Access level for admins (1-5)" },
        "adminCategory": { "type": "string", "description": "Department or category for admin access" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Herbal products available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "imageUrl": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean", "description": "Whether the product is featured on the homepage" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Spiritual consultation and divination requests",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string" },
        "healerId": { "type": "string" },
        "healerName": { "type": "string" },
        "type": { "type": "string", "enum": ["Ifa Divination", "Spiritual Guidance", "Destiny Reading", "Spiritual Cleansing", "Traditional Healing"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "questions": { "type": "string" },
        "results": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientUid", "type", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders for herbal products",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled"] },
        "paymentReference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientUid", "customerName", "email", "items", "totalAmount", "status", "paymentReference"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational courses in the Ifa training academy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "instructor": { "type": "string" },
        "price": { "type": "number" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Individual lessons within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "order"]
    },
    "Babalawo": {
      "title": "Babalawo",
      "description": "Traditional Babaláwos and spiritual guides",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "availability": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "specialty", "bio", "availability"]
    },
    "StaffMember": {
      "title": "StaffMember",
      "description": "Information about clinic or temple staff",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "profileVideoUrl": { "type": "string", "format": "uri", "description": "URL to the staff member's profile video" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "email", "status"]
    },
    "YouTubeVideo": {
      "title": "YouTubeVideo",
      "description": "Educational or promotional YouTube videos",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "youtubeId": { "type": "string" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "youtubeId"]
    },
    "Page": {
      "title": "Page",
      "description": "Custom content pages for the website",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "content"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application settings including site info, ecommerce and appearance",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "siteTagline": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "footerText": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactAddress": { "type": "string" },
        "socialLinks": { "type": "object" },
        "maintenanceMode": { "type": "boolean" },
        "ecommerce": { "type": "object" },
        "appearance": { "type": "object" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user-specific notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "booking", "system", "task"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Internal staff tasks and management",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assignedTo": { "type": "string", "description": "UID of assigned staff" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews from customers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "text", "createdAt"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Questions",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "integer" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "answer", "order"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection of user profiles" },
    "products": { "schema": "Product", "description": "Collection of herbal products" },
    "products/{productId}/reviews": { "schema": "Review", "description": "Sub-collection of reviews for a specific product" },
    "consultations": { "schema": "Consultation", "description": "Collection of consultation bookings" },
    "orders": { "schema": "Order", "description": "Collection of product orders" },
    "courses": { "schema": "Course", "description": "Collection of training courses" },
    "courses/{courseId}/lessons": { "schema": "Lesson", "description": "Sub-collection of lessons for a specific course" },
    "babalawos": { "schema": "Babalawo", "description": "Collection of traditional Babaláwos" },
    "staff": { "schema": "StaffMember", "description": "Collection of staff members" },
    "videos": { "schema": "YouTubeVideo", "description": "Collection of YouTube videos" },
    "pages": { "schema": "Page", "description": "Collection of custom content pages" },
    "settings": { "schema": "Setting", "description": "Collection of global application settings" },
    "faqs": { "schema": "FAQ", "description": "Collection of frequently asked questions" }
  }
}
