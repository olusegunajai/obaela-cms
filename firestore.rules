rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin']) ||
         request.auth.token.email == "dbest4real2009@gmail.com"); // Default admin
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin') ||
         request.auth.token.email == "dbest4real2009@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['super-admin', 'admin', 'client'];
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.clientUid is string &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.email is string &&
             data.items is list &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'paid', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.paymentReference is string;
    }

    function isValidBabalawo(data) {
      return data.name is string && data.name.size() > 0 &&
             data.specialty is string && data.specialty.size() > 0 &&
             data.bio is string && data.bio.size() > 0 &&
             data.availability is string && data.availability.size() > 0;
    }

    function isValidStaff(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string && data.role.size() > 0 &&
             data.email is string &&
             data.status in ['active', 'inactive'];
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() > 0 &&
             data.youtubeId is string && data.youtubeId.size() > 0;
    }

    function isValidPage(data) {
      return data.slug is string && data.slug.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0;
    }

    function isValidSetting(data) {
      return data.key is string && data.key.size() > 0 &&
             data.value is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isSuperAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isSuperAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /consultations/{consultationId} {
      allow read: if isAuthenticated() && (resource.data.clientUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.clientUid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.clientUid == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.clientUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.clientUid == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /lessons/{lessonId} {
        allow read: if isAuthenticated() && (
          isAdmin() || 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrollments/$(courseId))
        );
        allow write: if isAdmin();
      }
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /babalawos/{babalawoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBabalawo(request.resource.data);
    }

    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin() && isValidStaff(request.resource.data);
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidVideo(request.resource.data);
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPage(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin(); // Only admins can send notifications for now, or we can expand this
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSetting(request.resource.data);
    }
  }
}
