rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdminEmail() {
      return isSignedIn() && request.auth.token.email == "dbest4real2009@gmail.com";
    }

    function isAdmin() {
      return isSuperAdminEmail() || 
             (isSignedIn() && 
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin']);
    }

    function isSuperAdmin() {
      return isSuperAdminEmail() || 
             (isSignedIn() && 
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.role in ['super-admin', 'admin', 'client'];
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.clientUid is string &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.email is string &&
             data.items is list &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'paid', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidReview(data) {
      return data.userId is string &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.text is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles & Subcollections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isSuperAdmin()) && isValidUser(request.resource.data);

      match /enrollments/{courseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
        
        match /completions/{lessonId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }
      }
    }

    // Products & Reviews
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidReview(request.resource.data);
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // Consultations
    match /consultations/{consultationId} {
      allow read: if isSignedIn() && (resource.data.clientUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.clientUid == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.clientUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.clientUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.clientUid == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin();
    }

    // Courses & Lessons
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /lessons/{lessonId} {
        allow read: if true; // Content access level is managed in UI, or we can restrict:
        // allow read: if isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)/enrollments/$(courseId));
        allow write: if isAdmin();
      }
    }

    // Content Collections
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /babalawos/{babalawoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /test/{docId} {
      allow read, write: if true;
    }

    // Site Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
